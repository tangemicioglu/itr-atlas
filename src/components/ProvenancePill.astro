---
type Provenance =
  | "author-reported-verified"
  | "author-reported-unverified"
  | "recomputed-omitted";
interface Props { provenance: Provenance; }
const { provenance } = Astro.props;
const LABELS: Record<Provenance, string> = {
  "author-reported-verified": "Author-reported · reproduced",
  "author-reported-unverified": "Author-reported · not reproduced",
  "recomputed-omitted": "Recomputed · paper omitted",
};
const recomputed = provenance.startsWith("recomputed");
---
<span class={`pill ${recomputed ? "recomp" : "auth"}`}>{LABELS[provenance]}</span>
<style>
  .pill { display: inline-block; font-size: 10.5px; letter-spacing: 0.3px;
    padding: 3px 8px; border-radius: 6px; }
  .auth { background: var(--prov-auth-bg); color: var(--prov-auth-ink); }
  .recomp { background: var(--prov-recomp-bg); color: var(--prov-recomp-ink); }
</style>
