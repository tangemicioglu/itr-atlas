---
import Tag from "./Tag.astro";
import ProvenancePill from "./ProvenancePill.astro";
import { formatBitsPerSecond } from "../lib/itr/math";
import { scoreTypeLabel } from "../lib/itr/scoring";
import type { ScoreType } from "../lib/itr/scoring";
import { url } from "../lib/url";

type Provenance = "author-reported-verified" | "author-reported-unverified" | "recomputed-omitted";
/** One displayable score: its value, how it was derived, and (for strictest) which family won. */
interface ScoreOption { v: number; prov: Provenance; type?: ScoreType; }

interface Props {
  id: string;
  name: string;
  image?: string;
  modalityTags: string[];
  invasiveness: "non-invasive" | "partially-invasive" | "invasive";
  miniStat: string;
  // { strictest: ScoreOption | null, [scoreType]: ScoreOption }. The number shown
  // is the strictest by default and swaps client-side when the score selector changes.
  scores: Record<string, ScoreOption | null>;
  rankable?: boolean;
  system?: string;
  technique?: string;
  year?: number;
}
const { id, name, image, modalityTags, invasiveness, miniStat, scores, rankable = true, system, technique, year } = Astro.props;
const invasive = invasiveness !== "non-invasive";
const def = scores.strictest;
const defMethod = def?.type ? scoreTypeLabel(def.type) : "";
---
<a class="card"
   href={url(`/interfaces/${id}`)}
   data-name={name.toLowerCase()}
   data-modality={[...modalityTags, invasiveness].join(" ").toLowerCase()}
   data-itr={def?.v ?? ""}
   data-scores={JSON.stringify(scores)}
   data-rankable={String(rankable)}
   data-system={system}
   data-technique={technique}
   data-year={year}>
  {image && <div class="photo"><img src={image} alt={name} /></div>}
  <div class="body">
    <div class="name">{name}</div>
    <div class="tags">
      {modalityTags.map((t) => <Tag label={t} variant="modality" />)}
      {invasive && <Tag label={invasiveness} variant="invasive" />}
    </div>
    <div class="statrow">
      <div class="itr">
        <span class="itr-val">{def ? formatBitsPerSecond(def.v) : "N/A"}</span>
        {def && <small> bits/s</small>}
      </div>
      <div class="mini">{miniStat}<br /><b class="method">{defMethod}</b></div>
    </div>
    {def && <ProvenancePill provenance={def.prov} />}
  </div>
</a>
<style>
  .card { display: block; background: var(--card); border: 1px solid var(--hairline);
    border-radius: var(--radius); overflow: hidden; text-decoration: none; color: var(--ink);
    transition: transform 0.12s, box-shadow 0.12s; }
  .card:hover { transform: translateY(-3px); box-shadow: 0 8px 22px rgba(40, 35, 25, 0.1); }
  .photo { height: 96px; background: var(--photo); color: var(--muted);
    display: flex; align-items: center; justify-content: center; font-size: 10px; }
  .photo img { width: 100%; height: 100%; object-fit: cover; }
  .body { padding: 13px 15px 15px; }
  .name { font-size: 15px; font-weight: 700; line-height: 1.25; }
  .tags { display: flex; gap: 5px; margin: 8px 0 12px; flex-wrap: wrap; }
  .statrow { display: flex; align-items: baseline; justify-content: space-between;
    border-top: 1px solid var(--hairline); padding-top: 11px; }
  .itr { font-size: 26px; font-weight: 800; line-height: 1; }
  .itr small { font-size: 11px; font-weight: 500; color: var(--muted); }
  .mini { text-align: right; font-size: 11px; color: var(--muted); }
  .mini b { color: var(--ink); }
  .body :global(.pill) { margin-top: 9px; }
  /* Greyed when the selected score type has no value for this entry. */
  .card.noscore { opacity: 0.5; }
  .card.noscore .itr { color: var(--muted); font-weight: 700; }
  .card.noscore :global(.pill) { visibility: hidden; }
</style>
