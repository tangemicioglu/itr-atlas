---
import BaseLayout from "../layouts/BaseLayout.astro";
// TODO: replace with the real Google Form URL once created.
const FORM_URL = "";
---
<BaseLayout title="Submit an interface | ITR Atlas">
  <article class="prose">
    <h1>Submit an interface</h1>
    <p>Know an interface we're missing? Propose it through the form below. Submissions are reviewed
       and curated by hand, so there's no open write access.</p>
    <p>You'll need: the source paper or DOI, the reported accuracy and timing, and the number of
       targets (or the relevant modality-specific inputs).</p>
    {FORM_URL
      ? <p><a class="cta" href={FORM_URL}>Open the submission form →</a></p>
      : <p class="pending">The submission form is being set up. Check back soon.</p>}
  </article>
</BaseLayout>

<style>
  .prose { max-width: 70ch; }
  .prose h1 { font-size: 28px; margin: 24px 0 8px; }
  .cta { display: inline-block; margin-top: 12px; background: var(--accent); color: #fff;
    padding: 10px 16px; border-radius: 8px; text-decoration: none; font-size: 14px; }
  .pending { color: var(--muted); }
</style>
