---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/Tag.astro";
import SourceList from "../../components/SourceList.astro";
import CalculationBlock from "../../components/CalculationBlock.astro";
import { resolveCalculation } from "../../lib/itr/resolve";
import { url } from "../../lib/url";

export async function getStaticPaths() {
  const entries = await getCollection("interfaces");
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const data = entry.data;

const resolved = data.calculations.map((c) => ({ calc: c, result: resolveCalculation(c) }));
const reference = resolved.find((r) => r.calc.id === data.referenceCalculationId) ?? resolved[0];
// When the designated calc is itself a ceiling, the entry has no ranked rate.
const rankable = !reference.calc.notUsedForRanking;
const additional = resolved.filter((r) => r !== reference && !r.calc.notUsedForRanking);
const supplementary = resolved.filter((r) => r !== reference && r.calc.notUsedForRanking);
const invasive = data.invasiveness !== "non-invasive";

const as = data.actionSpace;
const KIND_LABEL: Record<typeof as.kind, string> = {
  "fixed-set": "Fixed set of targets",
  "context-dependent": "Context-dependent (the live set changes per step)",
  continuous: "Continuous control space",
};
const PRIOR_LABEL: Record<typeof as.prior, string> = {
  uniform: "Uniform — all actions assumed equally likely",
  "non-uniform": "Non-uniform — some actions more likely than others",
  "context-conditioned": "Context-conditioned — likelihoods depend on prior actions",
};
// Comparability is governed by the realized-output rule, not Wolpaw's uniform-prior
// assumption (which the methodology now deliberately violates by baking in the
// language prior). Entries are commensurable when they share an estimator and a
// predictor: continuous control ranks on Fitts; closed non-language command sets on
// log2(N)/Wolpaw; everything else on the shared ~1 bit/char language predictor;
// ceiling-only entries are not ranked at all.
const rankedOnRawSelection =
  reference.calc.compute?.method === "wolpaw" ||
  reference.calc.compute?.method === "confusion-mi";
const comparabilityClass = reference.calc.notUsedForRanking
  ? "ceiling"
  : as.kind === "continuous" && rankedOnRawSelection
    ? "pointing-selection"
    : as.kind === "continuous"
    ? "pointing"
    : rankedOnRawSelection
      ? "selection"
      : "language";
const COMPARABILITY: Record<string, string> = {
  ceiling:
    "The figure above is a ceiling, not a measured throughput — a raw-channel capacity or an assumed-rate estimate — so it is not ranked. Compare it only to other ceilings, and weigh the derivation rather than the headline.",
  pointing:
    "Ranked on Fitts throughput: the index of difficulty, log₂(A/W + 1), per movement. Directly comparable to the other continuous-pointing entries — mouse, trackball, stylus, gaze and the cursor BCIs. Set against the language entries (keyboards, spellers, speech) it crosses estimators: both report bits/min, but one measures movement difficulty and the other text information, so compare within the family first.",
  "pointing-selection":
    "Ranked on a Wolpaw-style target-acquisition estimate over cued endpoints. This is a continuous cursor task, so compare it carefully with the Fitts-ranked pointing entries: the number reflects the published target set and completion rate, not a full Fitts effective-width throughput.",
  selection:
    "Ranked on the raw selection rate — log₂(N) over the real action set, discounted by accuracy. This is the right measure here because the output is a closed command set, not free English, so no language predictor applies. Comparable to the other command-and-control entries; against the text entries it reads high per selection, since a few large choices carry more raw bits than the ~1 bit/character of natural language.",
  language:
    "Ranked on the information the output actually delivers as English, under one predictor held constant across the whole atlas (≈1 bit per character). That shared predictor is what makes it directly comparable to every other text entry — keyboards, spellers, silent speech and speech BCIs — regardless of each entry's prior or vocabulary size. Any raw-channel figure shown below (Wolpaw or log₂(N)) is a ceiling, not this rank.",
};
const sizeLabel = as.size === "continuous" ? "Continuous" : `${as.size} distinguishable actions`;
---
<BaseLayout title={`${data.name} — ITR Atlas`}>
  <a class="back" href={url("/")}>← All interfaces</a>

  <header class="head">
    {data.image && <div class="photo"><img src={data.image} alt={data.name} /></div>}
    <div>
      <h1>{data.name}</h1>
      <div class="tags">
        {data.modalityTags.map((t) => <Tag label={t} variant="modality" />)}
        {invasive && <Tag label={data.invasiveness} variant="invasive" />}
        {data.year && <Tag label={String(data.year)} variant="neutral" />}
      </div>
    </div>
  </header>

  <h2>Inputs</h2>
  <p class="seclbl">The measured or assumed values behind the calculations, each with its source.</p>
  <dl class="inputs">
    {data.inputs.map((i) => (
      <div>
        <dt><span class="sym">{i.symbol}</span> = {i.value}{i.unit ? ` ${i.unit}` : ""}</dt>
        <dd>{i.sourceNote}</dd>
      </div>
    ))}
  </dl>

  <h2>{rankable ? "Reference ITR" : "Headline ceiling (not ranked)"}</h2>
  <p class="seclbl">{rankable
    ? "One designated method per entry — the number used for cross-comparison."
    : "This entry has no measured communication rate, so it is not ranked. The figure below is a ceiling computed from an assumed rate, kept for documentation only."}</p>
  <CalculationBlock
    method={reference.calc.method}
    kind={reference.calc.kind}
    provenance={reference.calc.provenance}
    resultBitsPerMin={reference.result.resultBitsPerMin}
    steps={reference.result.steps}
    flawReason={reference.calc.flawReason}
    isReference={rankable}
  />

  <p class="modnote">
    <b>What counts as a bit depends on the action space.</b> The number of distinguishable
    actions and how likely each one is are design choices of the task, not the sensing hardware.
    The same modality can present a fixed set of targets, a set pruned per step by a grammar or
    language model, or a continuous control space — each changes how many actions are live and how
    the probability mass is spread, and therefore the information per selection. Read the action
    space below before comparing headline numbers across entries.
  </p>

  <h2>Action space</h2>
  <p class="seclbl">What the user can produce at each step, and how those options are distributed.</p>
  <dl class="aspace">
    <div><dt>Structure</dt><dd>{KIND_LABEL[as.kind]}</dd></div>
    <div><dt>Size</dt><dd>{sizeLabel}</dd></div>
    <div><dt>Prior</dt><dd>{PRIOR_LABEL[as.prior]}</dd></div>
    {as.notes && <div><dt>Notes</dt><dd>{as.notes}</dd></div>}
  </dl>
  <p class="compare">
    <span class="compare-label">Comparability</span>
    {COMPARABILITY[comparabilityClass]}
  </p>

  {additional.length > 0 && (
    <>
      <h2>Additional derivations</h2>
      {additional.map((r) => (
        <CalculationBlock
          method={r.calc.method} kind={r.calc.kind} provenance={r.calc.provenance}
          resultBitsPerMin={r.result.resultBitsPerMin} steps={r.result.steps}
          flawReason={r.calc.flawReason} />
      ))}
    </>
  )}

  {supplementary.length > 0 && (
    <>
      <h2>Supplementary calculations</h2>
      <p class="seclbl">Shown for transparency — not used for ranking.</p>
      {supplementary.map((r) => (
        <CalculationBlock
          method={r.calc.method} kind={r.calc.kind} provenance={r.calc.provenance}
          resultBitsPerMin={r.result.resultBitsPerMin} steps={r.result.steps}
          flawReason={r.calc.flawReason} />
      ))}
    </>
  )}

  <h2>Source</h2>
  <SourceList source={data.source} references={data.references} />
</BaseLayout>

<style>
  .back { display: inline-block; margin: 18px 0; font-size: 13px; color: var(--muted); text-decoration: none; }
  .head { display: flex; gap: 24px; align-items: flex-start; margin-bottom: 26px; }
  .photo { width: 220px; height: 150px; flex: none; border-radius: 14px; background: var(--photo);
    color: var(--muted); display: flex; align-items: center; justify-content: center; font-size: 12px; overflow: hidden; }
  .photo img { width: 100%; height: 100%; object-fit: cover; }
  h1 { margin: 0 0 14px; font-size: 26px; letter-spacing: -0.2px; }
  h2 { font-size: 18px; margin: 30px 0 4px; }
  .tags { display: flex; gap: 9px; flex-wrap: wrap; }
  .seclbl { font-size: 13px; color: var(--muted); margin: 0 0 16px; }
  .modnote { font-size: 12.5px; color: var(--muted); background: var(--card);
    border: 1px dashed var(--hairline); border-radius: 9px; padding: 11px 14px; margin-top: 14px; }
  .aspace { margin: 0; background: var(--card); border: 1px solid var(--hairline);
    border-radius: var(--radius); padding: 4px 20px; }
  .aspace > div { display: flex; padding: 11px 0; border-bottom: 1px solid var(--hairline); }
  .aspace > div:last-child { border-bottom: none; }
  .aspace dt { width: 110px; flex: none; color: var(--muted); font-size: 12px;
    text-transform: uppercase; letter-spacing: 0.6px; margin: 0; }
  .aspace dd { margin: 0; font-size: 14px; }
  .inputs { margin: 0 0 6px; }
  .inputs > div { padding: 12px 0; border-bottom: 1px solid var(--hairline); }
  .inputs > div:last-child { border-bottom: none; }
  .inputs dt { font-size: 14px; margin: 0 0 4px; font-family: var(--font-mono, monospace); color: var(--ink); }
  .inputs dt .sym { color: var(--accent); font-weight: 700; }
  .inputs dd { margin: 0; font-size: 13px; color: var(--muted); line-height: 1.5; max-width: 80ch; }
  .compare { font-size: 12.5px; color: var(--muted); background: var(--card);
    border: 1px dashed var(--hairline); border-radius: 9px; padding: 11px 14px; margin-top: 12px; }
  .compare-label { display: inline-block; font-size: 10px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.7px; color: var(--ink); margin-right: 8px; }
</style>
